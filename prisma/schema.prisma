// =============================================================================
// Kosloski Law CRM — Prisma Schema
// =============================================================================
// Comprehensive data model for a plaintiffs' civil-rights practice management
// application. Covers matters, contacts, email, time & billing, documents,
// evidence, deadlines, tasks, trust accounting, and team management.
//
// Database: SQLite for local dev (swap to PostgreSQL for production).
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// =============================================================================
// USERS & AUTHENTICATION
// =============================================================================

/// Firm team member — attorneys, paralegals, investigators, admin staff.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  initials  String   /// Two-letter initials for avatar display (e.g. "JM")
  role      String   /// Partner | Managing | Counsel | Paralegal | Investigator | Intake | Admin
  avatarUrl String?  /// Optional profile photo URL
  phone     String?
  barNumber String?  /// State bar number (attorneys only)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  matterAssignments MatterTeamMember[]
  timeEntries       TimeEntry[]
  tasks             Task[]            @relation("TaskOwner")
  activityLogs      ActivityLog[]
  notes             Note[]
  deadlines         Deadline[]        @relation("DeadlineOwner")
  emailAccounts     EmailAccount[]
  approvals         SettlementApproval[]
  flaggedMoments    FlaggedMoment[]
  matterPins        UserMatterPin[]
  noteReads         NoteRead[]
  noteReactions     NoteReaction[]

  @@map("users")
}

// =============================================================================
// MATTERS (Cases)
// =============================================================================

/// Firm-configurable practice area (§1983, Housing/FHA, etc.). Every
/// Matter belongs to exactly one. Stages are scoped per-area so e.g.
/// a criminal case can have a different lifecycle than a class action.
/// Soft-delete only (`isActive = false`) so historical matters keep
/// working even after an area is retired.
model PracticeArea {
  id           String   @id @default(cuid())
  name         String   @unique /// Display name, e.g. "§1983" or "Housing/FHA"
  label        String?  /// Optional longer label shown in sidebar/reports, e.g. "§1983 · Civil rights"
  color        String   @default("#2563a8") /// Hex color — used for matter dots, sidebar, kanban
  order        Int      @default(0) /// Sort order in pickers and settings UI
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stages   MatterStage[]
  matters  Matter[]

  @@map("practice_areas")
}

/// Lifecycle stage for a matter within a single practice area. Ordered
/// via `order`. `isTerminal` marks closing states (e.g. Settled, Closed)
/// which are excluded from "open matter" aggregations and displayed in
/// a muted style on the stage stepper.
model MatterStage {
  id              String   @id @default(cuid())
  practiceAreaId  String
  practiceArea    PracticeArea @relation(fields: [practiceAreaId], references: [id], onDelete: Cascade)
  name            String   /// Display name, e.g. "Intake" or "Discovery"
  order           Int      @default(0) /// Position within the area's lifecycle
  isTerminal      Boolean  @default(false) /// True for closing states (Settled, Closed)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matters Matter[]

  @@unique([practiceAreaId, name])
  @@index([practiceAreaId, order])
  @@map("matter_stages")
}

/// A legal matter (case) — the central entity of the application.
model Matter {
  id             String   @id @default(cuid())
  name           String   /// Display name, e.g. "Alvarez v. City of Aurora et al."
  caseNumber     String?  /// Court docket number, e.g. "2026-CV-00481"
  practiceAreaId String   /// FK → practice_areas
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id])
  stageId        String   /// FK → matter_stages (must belong to the same practice area)
  stage          MatterStage  @relation(fields: [stageId], references: [id])
  court          String?  /// Court and judge, e.g. "D. Colorado · Hon. L. Martinez"
  filedDate      DateTime?
  trialDate      DateTime?
  feeStructure   String   @default("contingent") /// contingent | hourly | flat | hybrid | pro_bono
  trustBalance   Float    @default(0) /// Current IOLTA trust balance for this matter
  wipAmount      Float    @default(0) /// Work-in-progress (unbilled hours value)
  description    String?  /// Brief case summary
  color          String   @default("#2563a8") /// Color dot for UI display — snapshot from practiceArea.color on create
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Client relationship
  clientId String?
  client   Contact? @relation("MatterClient", fields: [clientId], references: [id])

  // Opposing party
  opposingParty    String? /// Name of opposing party/counsel
  opposingFirm     String? /// Opposing counsel's firm

  // Relationships
  teamMembers      MatterTeamMember[]
  contacts         MatterContact[]
  documents        Document[]
  evidence         Evidence[]
  deadlines        Deadline[]
  timeEntries      TimeEntry[]
  invoices         Invoice[]
  tasks            Task[]
  notes            Note[]
  emailThreads     EmailThread[]
  activityLogs     ActivityLog[]
  calendarEvents   CalendarEvent[]
  trustTransactions TrustTransaction[]
  settlements      Settlement[]
  pins             UserMatterPin[]

  @@index([stageId])
  @@index([practiceAreaId])
  @@index([clientId])
  @@map("matters")
}

/// Per-user pin of a matter — controls which matters appear in a given
/// user's "Pinned matters" sidebar section. Replaces the former global
/// `Matter.isPinned` boolean so attorneys/paralegals/etc. can each
/// curate their own pin list.
model UserMatterPin {
  userId    String
  matterId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@id([userId, matterId])
  @@index([userId])
  @@index([matterId])
  @@map("user_matter_pins")
}

/// Join table linking team members to matters with their role on the case.
model MatterTeamMember {
  id        String   @id @default(cuid())
  matterId  String
  userId    String
  role      String   /// lead | co_counsel | paralegal | investigator | of_counsel
  createdAt DateTime @default(now())

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matterId, userId])
  @@map("matter_team_members")
}

// =============================================================================
// CONTACTS & PARTIES
// =============================================================================

/// Any person or organization involved in the firm's work — clients, opposing
/// parties, witnesses, experts, courts, vendors, medical providers, etc.
model Contact {
  id              String   @id @default(cuid())
  name            String
  email           String?
  /// Denormalized primary phone — kept in sync with the primary
  /// ContactPhone row (via writes in src/app/actions/parties.ts).
  /// Existing reads across the app keep working; new code that
  /// needs the full list queries `phones`.
  phone           String?
  organization    String?  /// Firm, company, or agency name
  type            String   /// client | opposing_counsel | witness | expert | judge | court | vendor | medical_provider | government | other
  address         String?
  city            String?
  state           String?
  zip             String?
  notes           String?
  conflictStatus  String   @default("clear") /// clear | flagged | override
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  mattersAsClient MatterContact[]
  clientMatters   Matter[]  @relation("MatterClient")
  phones          ContactPhone[]

  @@index([type])
  @@index([name])
  @@map("contacts")
}

/// A phone number on a contact. Contacts can have many — a cell,
/// office, fax, etc. Exactly one per contact may be marked
/// `isPrimary`; the primary's `number` is mirrored onto
/// `Contact.phone` for backward compatibility with existing reads.
model ContactPhone {
  id        String   @id @default(cuid())
  contactId String
  /// Free-text label (Mobile / Office / Home / Fax / custom).
  label     String?
  number    String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([contactId, isPrimary])
  @@map("contact_phones")
}

/// Join table linking contacts to matters. `category` is the coarse
/// display bucket the Parties tab groups by (client, opposing,
/// lay_witness, expert_witness, other); `role` is the optional
/// finer-grained subdivision the firm can set (plaintiff, defendant,
/// GAL, medical provider, etc.).
///
/// TODO (settings): firm-configurable category list, same pattern as
/// practice areas in /settings. For now the five categories above
/// are hardcoded in src/lib/party-constants.ts.
model MatterContact {
  id        String   @id @default(cuid())
  matterId  String
  contactId String
  category  String   @default("other") /// client | opposing | lay_witness | expert_witness | other
  role      String?  /// Optional subrole — plaintiff, defendant, opposing_counsel, GAL, medical_provider, etc.
  notes     String?

  /// Representation — who (if anyone) represents this non-client party.
  /// Only meaningful for opposing parties / witnesses / others; clients
  /// are represented by us. `isRepresented = false` explicitly means
  /// pro se / self-represented; null means unknown. The contact fields
  /// are free-text for now — future: link to a Contact record so
  /// cross-matter repeat counsel coalesces into one entry.
  isRepresented       Boolean?
  representationName  String?
  representationFirm  String?
  representationEmail String?
  representationPhone String?

  createdAt DateTime @default(now())

  matter  Matter  @relation(fields: [matterId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([matterId, contactId, category])
  @@index([category])
  @@map("matter_contacts")
}

// =============================================================================
// INTAKE / LEADS
// =============================================================================

/// Prospective client lead in the intake pipeline.
model Lead {
  id                  String   @id @default(cuid())
  name                String   /// Prospective client name
  email               String?
  phone               String?
  source              String?  /// web | referral | phone | walk_in | court_appointment
  sourceDetail        String?  /// Additional source info, e.g. "referral · Fox"
  summary             String?  /// Auto-extracted or manually entered case summary
  location            String?  /// Incident location
  dateOfIncident      DateTime?
  injuries            String?  /// Comma-separated or freeform description
  priorCounsel        Boolean  @default(false)
  score               Int?     /// Lead quality score 0-100
  liabilityAssessment String?  /// strong | moderate | weak
  damagesAssessment   String?  /// strong | moderate | weak
  defendantAbility    String?  /// Description of defendant's ability to satisfy judgment
  statuteWindow       Int?     /// Days remaining on statute of limitations
  conflictCheck       String   @default("pending") /// pending | clear | warn | conflict
  stage               String   @default("new") /// new | contacted | qualifying | meeting | converted | declined | hold
  declineReason       String?
  convertedMatterId   String?  /// If converted, links to the created matter
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([stage])
  @@index([score])
  @@map("leads")
}

// =============================================================================
// DOCUMENTS
// =============================================================================

/// A document associated with a matter — filings, contracts, correspondence, etc.
model Document {
  id          String   @id @default(cuid())
  matterId    String
  name        String   /// Filename or display title
  category    String   @default("other") /// filing | pleading | correspondence | contract | intake | discovery | expert_report | evidence | vendor | archive | other
  source      String?  /// ECF | email | scan | upload | generated | vendor
  fileUrl     String?  /// Storage URL or local path
  contentType String?  /// MIME type, e.g. "application/pdf"
  fileSize    Int?     /// Size in bytes
  status      String   @default("active") /// active | filed | received | review | archived
  uploadedBy  String?  /// User ID who uploaded
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId])
  @@index([category])
  @@map("documents")
}

// =============================================================================
// EVIDENCE
// =============================================================================

/// A piece of evidence — body camera footage, dashcam, audio, photos, etc.
/// Specialized for civil rights litigation where multimedia evidence is critical.
model Evidence {
  id             String   @id @default(cuid())
  matterId       String
  type           String   /// bodycam_video | dashcam_video | audio | transcript | image | document | dispatch | cad_entry
  description    String
  source         String?  /// Where evidence came from, e.g. "APD", "witness", "court"
  dateRecorded   DateTime? /// When the evidence was originally captured
  duration       String?  /// Length if video/audio, e.g. "00:14:22"
  fileUrl        String?
  fileSize       Int?
  resolution     String?  /// Video resolution, e.g. "1920×1080"
  fps            Int?     /// Video frame rate
  officerBadge   String?  /// Badge number if body camera
  incidentNumber String?
  status         String   @default("raw") /// raw | synced | transcribed | flagged | reviewed
  transcriptText String?  /// Full transcript text (if transcribed)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  matter         Matter          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  flaggedMoments FlaggedMoment[]
  syncLinks      EvidenceSync[]  @relation("EvidenceSyncSource")
  syncedWith     EvidenceSync[]  @relation("EvidenceSyncTarget")

  @@index([matterId])
  @@index([type])
  @@map("evidence")
}

/// A notable moment flagged in a piece of evidence (e.g. use-of-force incident).
model FlaggedMoment {
  id          String   @id @default(cuid())
  evidenceId  String
  timestamp   String   /// Position in media, e.g. "00:03:42"
  description String
  category    String   /// critical | emphasis | anomaly | miranda | use_of_force | contradiction
  flaggedById String   /// User who flagged this moment
  createdAt   DateTime @default(now())

  evidence  Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  flaggedBy User     @relation(fields: [flaggedById], references: [id])

  @@index([evidenceId])
  @@map("flagged_moments")
}

/// Synchronization links between evidence items (e.g. body cam + dashcam aligned).
model EvidenceSync {
  id             String @id @default(cuid())
  sourceId       String
  targetId       String
  timeOffset     Float  @default(0) /// Offset in seconds to align timelines

  source Evidence @relation("EvidenceSyncSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Evidence @relation("EvidenceSyncTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@map("evidence_syncs")
}

// =============================================================================
// DEADLINES & CALENDAR
// =============================================================================

/// A legal deadline — statute-driven, rule-driven, or manually created.
model Deadline {
  id          String    @id @default(cuid())
  matterId    String
  title       String    /// E.g. "CGIA notice due", "Discovery cutoff"
  dueDate     DateTime
  kind        String    @default("manual") /// critical | auto_rule | manual
  sourceType  String?   /// statute | scheduling_order | filing_rule | custom
  sourceRef   String?   /// Applicable statute or rule, e.g. "CRS §24-10-109"
  description String?   /// Explanation of why/how this deadline applies
  ownerId     String?   /// Responsible attorney
  status      String    @default("open") /// open | completed | overdue | waived
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  owner  User?  @relation("DeadlineOwner", fields: [ownerId], references: [id])
  notes  Note[] @relation("DeadlineNotes")

  @@index([matterId])
  @@index([dueDate])
  @@index([status])
  @@map("deadlines")
}

/// Per-user read state for a note. Presence of a row means the user
/// has seen that note; absence means it's still unread. The Notes
/// tab uses this to auto-expand threads with unread replies and
/// auto-collapse threads the user has already caught up on.
model NoteRead {
  userId String
  noteId String
  readAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@index([noteId])
  @@map("note_reads")
}

/// Emoji reaction on a note. Each (user, note, emoji) tuple is
/// unique — a user can add multiple different emojis to the same
/// note but can't stack the same one twice. Emoji is stored as its
/// literal character (e.g. "👍"); the UI draws from a small curated
/// palette so we don't need an EmojiDefinition table.
model NoteReaction {
  userId    String
  noteId    String
  emoji     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([userId, noteId, emoji])
  @@index([noteId])
  @@index([noteId, emoji])
  @@map("note_reactions")
}

/// A calendar event — hearings, depositions, meetings, blocks, etc.
model CalendarEvent {
  id          String   @id @default(cuid())
  matterId    String?  /// Null for firm-wide events
  title       String
  type        String   @default("meeting") /// meeting | deposition | hearing | intake | block_time | deadline | mediation | trial
  startTime   DateTime
  endTime     DateTime
  location    String?
  description String?
  isAllDay    Boolean  @default(false)
  zoomUrl     String?
  color       String?  /// Override color for display
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matter      Matter?             @relation(fields: [matterId], references: [id], onDelete: SetNull)
  attendees   CalendarAttendee[]
  notes       Note[]              @relation("CalendarEventNotes")
  timeEntries TimeEntry[]         @relation("CalendarEventTimeEntries")

  @@index([startTime])
  @@index([matterId])
  @@map("calendar_events")
}

/// An attendee of a calendar event.
model CalendarAttendee {
  id       String @id @default(cuid())
  eventId  String
  name     String
  email    String?
  status   String @default("pending") /// accepted | declined | tentative | pending

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("calendar_attendees")
}

// =============================================================================
// TIME TRACKING & BILLING
// =============================================================================

/// A time entry — the core billing unit. Tracks work done on a matter.
model TimeEntry {
  id            String    @id @default(cuid())
  matterId      String
  userId        String    /// Attorney or staff who did the work
  date          DateTime  /// Date the work was performed
  hours         Float     /// Duration in decimal hours (e.g. 1.5)
  activity      String    /// Short description, e.g. "Motion to compel · draft & file"
  narrative     String?   /// Detailed client-facing description
  utbmsCode     String?   /// UTBMS activity code, e.g. "A101"
  rate          Float?    /// Billing rate per hour (null for contingent)
  amount        Float?    /// Computed billable amount (hours × rate)
  billable      Boolean   @default(true)
  noCharge      Boolean   @default(false) /// Write-off flag
  privileged    Boolean   @default(false) /// Attorney-client privilege flag
  source        String    @default("manual") /// manual | timer | email | calendar | document | task | evidence
  sourceRef     String?   /// Reference to originating email/event/doc ID
  status        String    @default("draft") /// draft | submitted | billable | billed | written_off
  invoiceId     String?   /// Set when this entry is included in an invoice
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// Optional direct link to the calendar event this time entry
  /// came out of (a hearing, deposition, meeting, etc.). Stronger
  /// than sourceRef — a proper FK so we can query both directions.
  calendarEventId String?

  matter  Matter         @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id])
  invoice Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  notes   Note[]         @relation("TimeEntryNotes")
  event   CalendarEvent? @relation("CalendarEventTimeEntries", fields: [calendarEventId], references: [id], onDelete: SetNull)

  @@index([matterId])
  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([calendarEventId])
  @@map("time_entries")
}

/// An invoice sent to a client for a matter.
model Invoice {
  id           String    @id @default(cuid())
  invoiceNumber String   @unique /// Human-readable number, e.g. "2026-041"
  matterId     String
  clientId     String?   /// Contact ID for the billed client
  issueDate    DateTime
  dueDate      DateTime
  subtotal     Float     @default(0)
  taxAmount    Float     @default(0)
  totalAmount  Float     @default(0)
  paidAmount   Float     @default(0)
  status       String    @default("draft") /// draft | sent | open | overdue | paid | void
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  matter     Matter      @relation(fields: [matterId], references: [id], onDelete: Cascade)
  lineItems  TimeEntry[]

  @@index([matterId])
  @@index([status])
  @@map("invoices")
}

// =============================================================================
// TRUST ACCOUNTING (IOLTA)
// =============================================================================

/// An IOLTA trust account transaction — deposits, disbursements, and transfers.
model TrustTransaction {
  id          String   @id @default(cuid())
  matterId    String
  type        String   /// deposit | disbursement | transfer | refund | interest
  amount      Float    /// Positive for deposits, negative for disbursements
  description String
  reference   String?  /// Check number, wire confirmation, etc.
  date        DateTime
  createdBy   String?  /// User who recorded the transaction
  reconciled  Boolean  @default(false)
  createdAt   DateTime @default(now())

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId])
  @@index([date])
  @@map("trust_transactions")
}

// =============================================================================
// SETTLEMENTS
// =============================================================================

/// A settlement for a resolved matter — tracks distribution, liens, approvals.
model Settlement {
  id               String   @id @default(cuid())
  matterId         String
  grossAmount      Float    /// Total settlement amount
  firmFee          Float    @default(0) /// Attorney fee
  firmFeePercent   Float?   /// Fee percentage (e.g. 33.33)
  advancedCosts    Float    @default(0) /// Costs advanced by firm
  clientNet        Float    @default(0) /// Net amount to client
  status           String   @default("pending") /// pending | approved | disbursed | closed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  matter    Matter               @relation(fields: [matterId], references: [id], onDelete: Cascade)
  liens     SettlementLien[]
  approvals SettlementApproval[]

  @@index([matterId])
  @@map("settlements")
}

/// A lien against a settlement — medical providers, insurance subrogation, etc.
model SettlementLien {
  id               String  @id @default(cuid())
  settlementId     String
  lienholder       String  /// Name of lienholder
  lienholderType   String? /// hospital | physician | insurance | government | other
  originalAmount   Float
  negotiatedAmount Float?  /// Reduced amount after negotiation
  status           String  @default("pending") /// pending | negotiating | signed | verified | paid

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@map("settlement_liens")
}

/// An approval step in the settlement distribution workflow.
model SettlementApproval {
  id           String    @id @default(cuid())
  settlementId String
  step         Int       /// Order in approval chain (1, 2, 3, 4)
  label        String    /// E.g. "Client release", "Partner sign-off", "Bookkeeper reconciliation"
  approverId   String?   /// User who approved
  status       String    @default("pending") /// pending | approved | rejected
  approvedAt   DateTime?
  notes        String?

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  approver   User?      @relation(fields: [approverId], references: [id])

  @@map("settlement_approvals")
}

// =============================================================================
// EMAIL
// =============================================================================

/// A linked email account (e.g. Gmail OAuth integration).
model EmailAccount {
  id            String   @id @default(cuid())
  userId        String
  provider      String   @default("gmail") /// gmail | outlook | other
  emailAddress  String
  accessToken   String?  /// OAuth access token (encrypted in production)
  refreshToken  String?  /// OAuth refresh token (encrypted in production)
  syncStatus    String   @default("disconnected") /// connected | syncing | disconnected | error
  lastSyncAt    DateTime?
  threadsIndexed Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  threads EmailThread[]

  @@unique([userId, emailAddress])
  @@map("email_accounts")
}

/// An email thread — a conversation chain with one or more messages.
model EmailThread {
  id             String   @id @default(cuid())
  accountId      String
  matterId       String?  /// Null for unfiled emails
  externalId     String?  /// Gmail thread ID or provider-specific ID
  subject        String
  snippet        String?  /// Preview text for thread list
  isRead         Boolean  @default(false)
  isStarred      Boolean  @default(false)
  isArchived     Boolean  @default(false)
  hasAttachments Boolean  @default(false)
  messageCount   Int      @default(1)
  lastMessageAt  DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account  EmailAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  matter   Matter?        @relation(fields: [matterId], references: [id], onDelete: SetNull)
  messages EmailMessage[]
  labels   EmailLabel[]

  @@index([accountId])
  @@index([matterId])
  @@index([lastMessageAt])
  @@map("email_threads")
}

/// A single email message within a thread.
model EmailMessage {
  id           String   @id @default(cuid())
  threadId     String
  externalId   String?  /// Gmail message ID
  fromName     String
  fromEmail    String
  toRecipients String   /// JSON array of {name, email} objects
  ccRecipients String?  /// JSON array of {name, email} objects
  body         String   /// Email body text (HTML or plain)
  sentAt       DateTime
  isPrivileged Boolean  @default(false) /// Flagged as attorney-client privileged
  createdAt    DateTime @default(now())

  thread      EmailThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments EmailAttachment[]

  @@index([threadId])
  @@map("email_messages")
}

/// An attachment on an email message.
model EmailAttachment {
  id          String @id @default(cuid())
  messageId   String
  filename    String
  contentType String?
  fileSize    Int?   /// Size in bytes
  fileUrl     String? /// Storage URL after download

  message EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("email_attachments")
}

/// A label applied to an email thread (e.g. "privileged", "opposing-counsel", "auto-filed").
model EmailLabel {
  id       String @id @default(cuid())
  threadId String
  label    String /// privileged | opposing_counsel | auto_filed | urgent | follow_up | custom:*

  thread EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, label])
  @@map("email_labels")
}

// =============================================================================
// TASKS
// =============================================================================

/// A task or to-do item linked to a matter.
model Task {
  id          String    @id @default(cuid())
  matterId    String?   /// Null for firm-wide tasks
  title       String
  description String?
  priority    String    @default("normal") /// low | normal | high | urgent
  status      String    @default("open") /// open | in_progress | in_review | done | cancelled
  dueDate     DateTime?
  ownerId     String?   /// Assigned team member
  deadlineId  String?   /// If spawned from a deadline
  sortOrder   Int       @default(0) /// For manual ordering within status groups
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  matter Matter? @relation(fields: [matterId], references: [id], onDelete: Cascade)
  owner  User?   @relation("TaskOwner", fields: [ownerId], references: [id])
  notes  Note[]  @relation("TaskNotes")

  @@index([matterId])
  @@index([status])
  @@index([ownerId])
  @@map("tasks")
}

// =============================================================================
// NOTES
// =============================================================================

/// A note on a matter — strategy memos, research notes, internal chatter.
model Note {
  id        String   @id @default(cuid())
  matterId  String
  authorId  String
  content   String   /// Rich text content (stored as HTML or Markdown)
  type      String   @default("note") /// note | strategy | chatter | memo
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Threading — a reply to another note within the same matter. When
  /// the parent is deleted, the whole sub-thread goes with it so
  /// replies never dangle.
  parentNoteId String?

  /// Optional direct associations with other matter entities. A note
  /// with `calendarEventId` set is the "court note" for that hearing;
  /// `taskId` / `deadlineId` / `timeEntryId` attach the note to that
  /// specific record. At most one of these should be set per note;
  /// we don't enforce that in the DB to keep the schema simple.
  calendarEventId String?
  taskId          String?
  deadlineId      String?
  timeEntryId     String?

  matter    Matter         @relation(fields: [matterId], references: [id], onDelete: Cascade)
  author    User           @relation(fields: [authorId], references: [id])
  parent    Note?          @relation("NoteReplies", fields: [parentNoteId], references: [id], onDelete: Cascade)
  replies   Note[]         @relation("NoteReplies")
  event     CalendarEvent? @relation("CalendarEventNotes", fields: [calendarEventId], references: [id], onDelete: SetNull)
  task      Task?          @relation("TaskNotes", fields: [taskId], references: [id], onDelete: SetNull)
  deadline  Deadline?      @relation("DeadlineNotes", fields: [deadlineId], references: [id], onDelete: SetNull)
  timeEntry TimeEntry?     @relation("TimeEntryNotes", fields: [timeEntryId], references: [id], onDelete: SetNull)
  reads     NoteRead[]
  reactions NoteReaction[]

  @@index([matterId])
  @@index([parentNoteId])
  @@index([calendarEventId])
  @@index([taskId])
  @@index([deadlineId])
  @@index([timeEntryId])
  @@map("notes")
}

// =============================================================================
// ACTIVITY LOG
// =============================================================================

/// An activity log entry — tracks all notable events across the firm.
model ActivityLog {
  id        String   @id @default(cuid())
  matterId  String?  /// Null for firm-wide events
  userId    String?  /// User who triggered the action (null for system events)
  type      String   /// filing | email | evidence | deposition | task_complete | settlement | deposit | automation | deadline | note | document | time_entry
  icon      String?  /// Icon name for display, e.g. "gavel", "mail", "dollar"
  source    String?  /// PACER | Email | Evidence | SMS | Task | Trust | Automation | System
  title     String
  detail    String?  /// Extended description
  timestamp DateTime @default(now())

  matter Matter? @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id])

  @@index([matterId])
  @@index([timestamp])
  @@map("activity_logs")
}

// =============================================================================
// AUTOMATIONS
// =============================================================================

/// A reusable automation template — onboarding flows, document generation, etc.
model Automation {
  id          String   @id @default(cuid())
  name        String   /// E.g. "§1983 onboarding", "CGIA notice generation"
  description String?
  trigger     String?  /// intake_convert | deadline_approaching | manual | stage_change
  area        String?  /// Practice area this applies to (null = all)
  steps       String   /// JSON array of automation steps
  isActive    Boolean  @default(true)
  runCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("automations")
}
