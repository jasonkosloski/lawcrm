# Copy to .env and fill in. Never commit your real .env.

# Database — Postgres in every environment now.
#
# Production (Vercel): set DATABASE_URL to your POSTGRES_PRISMA_URL
# (the pgbouncer-pooled URL) and DIRECT_DATABASE_URL to your
# POSTGRES_URL_NON_POOLING (used by `prisma migrate` / `prisma db push`).
#
# Local dev: point DATABASE_URL at a Postgres of your choice — your
# Vercel branch DB, a local Postgres install, or the test container.
# Tests use a separate URL hard-coded in src/test/integration-setup.ts
# so this DATABASE_URL won't get clobbered when you run `npm test`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lawcrm_dev"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lawcrm_dev"

# Auth.js — used to sign session JWTs and CSRF tokens. Generate
# with: openssl rand -base64 32. Required in every environment.
AUTH_SECRET=

# Encrypts EmailAccount OAuth tokens (access/refresh) at rest —
# AES-256-GCM, enforced by a Prisma extension (src/lib/email-token-
# encryption.ts). Generate with: openssl rand -base64 32. Required
# before connecting any Gmail account. Rotating it orphans existing
# tokens (users reconnect their accounts) — don't lose it casually.
EMAIL_TOKEN_KEY=

# Document storage (ADR-015). Two drivers behind src/lib/file-storage.ts:
#
#   local        ./uploads/ on disk — dev default, zero setup.
#   vercel-blob  Vercel Blob — REQUIRED in production (the Vercel
#                serverless filesystem is ephemeral). Auto-selected
#                whenever BLOB_READ_WRITE_TOKEN is set.
#
# Production (Vercel): create a Blob store on the project — Vercel
# injects BLOB_READ_WRITE_TOKEN automatically. Nothing else to set.
#
# Local dev: leave BOTH unset. If `vercel env pull` drops the token
# into your .env, set STORAGE_DRIVER=local to stay on disk — client-
# direct blob uploads DON'T finish on localhost (Vercel's completion
# callback can't reach you), so blob-driver dev needs a tunnel.
# BLOB_READ_WRITE_TOKEN=
# STORAGE_DRIVER=local

# Optional. Auth.js v5 derives the URL from the request host by
# default — set this explicitly only when running behind a proxy/CDN.
# AUTH_URL="http://localhost:3000"

# Future providers (uncomment + set when wiring Google OAuth):
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
